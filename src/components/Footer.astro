---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="footer-brand">
			<h3>Le Cintre Privé</h3>
			<p>Style · Élégance · Sophistication</p>
		</div>

		<div class="footer-links">
			<div class="footer-section">
				<h4>Catégories</h4>
				<a href="/categories/mode-feminine-tunisie">Mode Féminine</a>
				<a href="/categories/style-et-conseils-vestimentaires">Style & Conseils</a>
				<a href="/categories/tendances-mode-saison">Tendances</a>
				<a href="/categories/guide-et-conseils-pratiques">Guides Pratiques</a>
			</div>

			<div class="footer-section">
				<h4>Suivez-nous</h4>
				<a href="https://www.instagram.com/lecintreprive" target="_blank">Instagram</a>
				<a href="/about">À Propos</a>
			</div>
		</div>
	</div>

	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} Le Cintre Privé. Tous droits réservés.</p>
		<p>Créé avec passion en Tunisie</p>
	</div>
</footer>

<style>
	footer {
		background: var(--text-primary);
		color: var(--warm-white);
		margin-top: 4rem;
	}

	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 4rem 2rem 2rem;
		display: grid;
		grid-template-columns: 1fr 2fr;
		gap: 4rem;
	}

	.footer-brand h3 {
		font-family: 'Playfair Display', serif;
		font-size: 2rem;
		font-weight: 700;
		color: var(--powder-blue);
		margin-bottom: 0.5rem;
	}

	.footer-brand p {
		color: var(--warm-white);
		opacity: 0.8;
		font-size: 0.9rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		margin: 0;
	}

	.footer-links {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 2rem;
	}

	.footer-section h4 {
		font-family: 'Playfair Display', serif;
		font-size: 1.25rem;
		color: var(--dusty-rose);
		margin-bottom: 1rem;
		font-weight: 600;
	}

	.footer-section {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.footer-section a {
		color: var(--warm-white);
		text-decoration: none;
		opacity: 0.8;
		transition: all 0.3s ease;
		border: none !important;
	}

	.footer-section a:hover {
		opacity: 1;
		color: var(--powder-blue);
		border: none !important;
	}

	.footer-bottom {
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		padding: 2rem;
		text-align: center;
		display: flex;
		justify-content: space-between;
		align-items: center;
		max-width: 1200px;
		margin: 0 auto;
	}

	.footer-bottom p {
		margin: 0;
		font-size: 0.9rem;
		opacity: 0.7;
		color: var(--warm-white);
	}

	@media (max-width: 768px) {
		.footer-content {
			grid-template-columns: 1fr;
			gap: 2rem;
			padding: 3rem 1rem 1rem;
		}

		.footer-links {
			grid-template-columns: repeat(2, 1fr);
		}

		.footer-bottom {
			flex-direction: column;
			gap: 0.5rem;
			padding: 1.5rem 1rem;
		}
	}

	@media (max-width: 480px) {
		.footer-links {
			grid-template-columns: 1fr;
		}

		.footer-brand h3 {
			font-size: 1.5rem;
		}
	}
</style>

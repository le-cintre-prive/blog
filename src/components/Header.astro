---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import instagram from '../assets/instagram-logo-facebook-2-svgrepo-com.svg';
import { Image } from 'astro:assets';
---

<header>
	<nav class="navbar">
		<div class="brand">
			<a href="/" class="brand-link">
				<span class="brand-main">Le Cintre</span>
				<span class="brand-accent">Privé</span>
			</a>
			<p class="tagline">Style · Élégance · Sophistication</p>
		</div>

		<div class="nav-center">
			<div class="internal-links">
				<HeaderLink href="/">Accueil</HeaderLink>
				<HeaderLink href="/categories/mode-feminine-tunisie">Mode Féminine</HeaderLink>
				<HeaderLink href="/categories/style-et-conseils-vestimentaires">Style & Conseils</HeaderLink>
				<HeaderLink href="/categories/tendances-mode-saison">Tendances</HeaderLink>
				<HeaderLink href="/categories/guide-et-conseils-pratiques">Guides Pratiques</HeaderLink>
			</div>
		</div>

		<div class="social-links">
			<a href="https://www.instagram.com/lecintreprive" target="_blank" class="instagram-link">
				<span class="sr-only">Suivez Le Cintre Privé sur Instagram</span>
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
					<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" fill="currentColor"/>
				</svg>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		background: var(--warm-white);
		backdrop-filter: blur(20px);
		border-bottom: 1px solid rgba(139, 87, 42, 0.08);
		position: sticky;
		top: 0;
		z-index: 100;
		box-shadow: var(--shadow-soft);
	}

	.navbar {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		max-width: 1200px;
		margin: 0 auto;
		padding: 1.5rem 2rem;
		gap: 2rem;
	}

	.brand {
		justify-self: start;
	}

	.brand-link {
		font-family: 'Playfair Display', serif;
		font-size: 1.75rem;
		font-weight: 700;
		text-decoration: none;
		color: var(--cognac-brown);
		display: flex;
		align-items: baseline;
		gap: 0.25rem;
		border: none !important;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.brand-link:hover {
		color: var(--dusty-rose);
		transform: translateY(-2px);
		border: none !important;
	}

	.brand-main {
		font-weight: 700;
	}

	.brand-accent {
		font-style: italic;
		font-weight: 400;
		color: var(--dusty-rose);
	}

	.tagline {
		font-size: 0.75rem;
		color: var(--text-secondary);
		margin: 0.25rem 0 0 0;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		font-weight: 300;
	}

	.nav-center {
		justify-self: center;
	}

	.internal-links {
		display: flex;
		gap: 2rem;
		align-items: center;
	}

	.internal-links a {
		color: var(--text-secondary);
		text-decoration: none;
		font-weight: 400;
		font-size: 0.95rem;
		position: relative;
		padding: 0.5rem 0;
		border: none !important;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.internal-links a::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		width: 0;
		height: 2px;
		background: linear-gradient(90deg, var(--dusty-rose), var(--powder-blue));
		transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.internal-links a:hover {
		color: var(--text-primary);
		border: none !important;
	}

	.internal-links a:hover::after {
		width: 100%;
	}

	.internal-links a.active {
		color: var(--cognac-brown);
		font-weight: 500;
		border: none !important;
	}

	.internal-links a.active::after {
		width: 100%;
	}

	.social-links {
		justify-self: end;
		display: flex;
		align-items: center;
	}

	.instagram-link {
		color: var(--text-secondary);
		padding: 0.75rem;
		border-radius: 12px;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		background: var(--soft-blue);
		border: none !important;
	}

	.instagram-link:hover {
		color: var(--dusty-rose);
		background: var(--blush-pink);
		transform: translateY(-2px);
		box-shadow: var(--shadow-soft);
		border: none !important;
	}

	/* Mobile responsive */
	@media (max-width: 1024px) {
		.navbar {
			padding: 1.25rem 1.5rem;
		}

		.internal-links {
			gap: 1.5rem;
		}
	}

	@media (max-width: 768px) {
		.navbar {
			grid-template-columns: 1fr auto;
			gap: 1rem;
			padding: 1rem;
		}

		.nav-center {
			display: none;
		}

		.brand-link {
			font-size: 1.5rem;
		}

		.tagline {
			font-size: 0.7rem;
		}

		.social-links {
			justify-self: end;
		}
	}

	@media (max-width: 480px) {
		.navbar {
			padding: 0.75rem;
		}

		.brand-link {
			font-size: 1.25rem;
		}

		.tagline {
			display: none;
		}
	}
</style>
